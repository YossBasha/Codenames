{
  "name": "client",
  "private": true,
  "version": "1.4.27",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "npm run build --prefix ../server && concurrently \"npm run build --prefix ../server -- --watch\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build --prefix ../server && npm run build && electron-builder",
    "android:sync": "npm run build && npx esbuild ../server/src/index.ts --bundle --platform=node --target=node18 --outfile=dist/nodejs/index.js --format=cjs --external:bridge && node -e \"const fs=require('fs'); fs.writeFileSync('dist/nodejs/package.json', JSON.stringify({name:'server',main:'index.js'}));\" && npx cap sync android",
    "android:build": "npm run android:sync && cd android && gradlew assembleDebug && node -e \"const fs=require('fs'); fs.renameSync('app/build/outputs/apk/debug/app-debug.apk', 'app/build/outputs/apk/debug/Codenames v' + process.env.npm_package_version + '.apk');\""
  },
  "build": {
    "appId": "com.codenames.app",
    "productName": "Codenames",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YossBasha",
        "repo": "Codenames"
      }
    ],
    "win": {
      "icon": "build/icon.png"
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/package.json",
        "to": "server/package.json"
      }
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@choreruiz/capacitor-node-js": "^1.0.2",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.16.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
